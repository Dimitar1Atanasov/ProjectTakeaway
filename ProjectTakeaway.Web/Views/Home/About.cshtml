@{
    ViewData["Title"] = "About Us";
}

<div class="about-hero">
    <div class="hero-overlay">
        <h1>Who Are We?</h1>
        <p>Delicious food, delivered fast, right to your doorstep!</p>
        
    </div>
</div>

<div class="about-container">

    <!-- Introduction -->
    <div class="about-intro">
        <p>
            Welcome to <strong>QuickBite!</strong> We are passionate about bringing delicious food straight to your doorstep.
            Our mission is simple: provide high-quality meals quickly, efficiently, and with a smile.
        </p>
        <p>
            At <strong>QuickBite</strong>, we believe that great food starts with great ingredients.
            Every dish is prepared with care and attention to detail, ensuring a memorable experience for every customer.
        </p>
        <p>
            Our team is made up of dedicated professionals who love what they do.
            From our chefs to our delivery staff, everyone shares the same goal: making your day better through amazing food.
        </p>
        <p>
            Whether you're ordering your favorite meal for lunch, dinner, or a late-night snack,
            <strong>QuickBite</strong> is here to satisfy your cravings and make ordering easy and fun.
        </p>
    </div>

    <!-- Fun Feature Cards -->
    <div class="about-features">
        <div class="feature-card">
            <div class="feature-icon">⚡</div>
            <h3>Fast Delivery</h3>
            <p>Get your meals in under 30 minutes, hot and fresh!</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">🍽️</div>
            <h3>Quality Ingredients</h3>
            <p>We source only the freshest ingredients for every dish.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">💳</div>
            <h3>Easy Payments</h3>
            <p>Secure and convenient payment options for hassle-free orders.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon">😄</div>
            <h3>Happy Staff</h3>
            <p>Our team loves what they do, making your experience even better!</p>
        </div>
    </div>

</div>
